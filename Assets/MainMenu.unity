  textLinkPrefab: {fileID: 0}
  render: {fileID: 365}
  Text: "Among Us uses AdMob ads after every match to make\nthis app free. By default,
    AdMob collects data for tailored\nads. AdMob will still use cookies, device ids,
    and coarse\ngeo data even for non-personalized ads. We cannot turn\nthis off,
    so we recommend buying the no-ad upgrade (2\nUSD) instead.\r\n\r\nIf you buy the
    no-ad upgrade, your friends will also get\nno ads whenever you host! If you've
    bought the upgrade\nbefore, open the store to recover the receipt."
  Color: {r: 1, g: 1, b: 1, a: 1}
